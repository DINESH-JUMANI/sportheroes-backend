# Server
NODE_ENV=development
PORT=3000
SWAGGER_ENABLED=true
# error | warn | info | http | debug
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:admin@localhost:5432/sportheroes

# App JWT (email/phone + password login)
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=sportheroes-api
AUTH_TOKEN_EXPIRY_DAYS=7

# Supabase Storage ONLY (not used for auth)
# Project Settings → API
# Project root only — do NOT add /rest/v1/
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional on server; use anon key in Flutter only if uploading client-side
SUPABASE_ANON_KEY=your-anon-key
