# Server
NODE_ENV=development
PORT=3000
SWAGGER_ENABLED=true
# error | warn | info | http | debug
LOG_LEVEL=debug

# Database (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportheroes

# App JWT (issued after Firebase phone auth verification)
# Use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=sportheroes-api
AUTH_TOKEN_EXPIRY_DAYS=7

# Firebase Admin SDK (service account)
# Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Keep the \n escapes when pasting the private key into a single-line .env value
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
