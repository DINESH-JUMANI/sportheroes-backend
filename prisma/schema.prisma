generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GenderType {
  male
  female
  other
  prefer_not_to_say

  @@map("gender_type")
}

enum SkillLevelType {
  beginner
  intermediate
  advanced
  professional

  @@map("skill_level_type")
}

enum TeamRoleType {
  admin
  captain
  vice_captain
  member

  @@map("team_role_type")
}

enum TournamentFormatType {
  league
  round_robin
  knockout

  @@map("tournament_format_type")
}

enum TournamentParticipantKind {
  individual
  team

  @@map("tournament_participant_kind")
}

enum TournamentStatusType {
  draft
  registration_open
  registration_closed
  ongoing
  completed
  cancelled

  @@map("tournament_status_type")
}

enum ParticipantStatusType {
  registered
  confirmed
  withdrawn
  disqualified

  @@map("participant_status_type")
}

enum MatchTypeKind {
  singles
  doubles
  team

  @@map("match_type_kind")
}

enum MatchStatusType {
  scheduled
  ongoing
  paused
  completed
  cancelled

  @@map("match_status_type")
}

enum MatchSideType {
  A
  B

  @@map("match_side_type")
}

enum SupportTicketStatusType {
  open
  in_progress
  resolved
  closed

  @@map("support_ticket_status_type")
}

model User {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid       String     @unique @map("firebase_uid") @db.VarChar(128)
  email             String?    @unique @db.VarChar(255)
  phoneNumber       String?    @map("phone_number") @db.VarChar(20)
  fullName          String     @map("full_name") @db.VarChar(150)
  displayName       String?    @map("display_name") @db.VarChar(50)
  profilePictureUrl String?    @map("profile_picture_url") @db.Text
  dateOfBirth       DateTime?  @map("date_of_birth") @db.Date
  gender            GenderType?
  city              String?    @db.VarChar(100)
  state             String?    @db.VarChar(100)
  country           String?    @db.VarChar(100)
  isActive          Boolean    @default(true) @map("is_active")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  playerSportProfiles    PlayerSportProfile[]
  teamsCreated         Team[]                 @relation("TeamCreator")
  teamsAsCaptain       Team[]                 @relation("TeamCaptain")
  teamsAsViceCaptain   Team[]                 @relation("TeamViceCaptain")
  teamMemberships      TeamMember[]
  tournamentsOrganized Tournament[]
  tournamentParticipants TournamentParticipant[]
  tournamentStandings  TournamentStanding[]
  matchesCreated       Match[]                @relation("MatchCreator")
  matchParticipants    MatchParticipant[]
  matchPointsRecorded  MatchPoint[]
  matchStatusChanges   MatchStatusLog[]
  playerStatistics     PlayerStatistics[]
  venuesCreated        Venue[]
  supportConcernsCreated SupportConcern[]
  supportTicketsCreated  SupportTicket[]
  supportTicketStatusChanges SupportTicketStatusLog[]

  @@index([phoneNumber], map: "idx_users_phone_number")
  @@map("users")
}

model Sport {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String   @unique @db.VarChar(50)
  code               String   @unique @db.VarChar(10)
  iconUrl            String?  @map("icon_url") @db.Text
  description        String?  @db.Text
  isTeamSport        Boolean  @default(false) @map("is_team_sport")
  defaultMatchFormat Json     @map("default_match_format")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  playerSportProfiles      PlayerSportProfile[]
  teams                    Team[]
  tournaments              Tournament[]
  matches                  Match[]
  playerStatistics         PlayerStatistics[]
  tableTennisRules         SportRulesTableTennis?
  badmintonRules           SportRulesBadminton?
  volleyballRules          SportRulesVolleyball?
  pickleballRules          SportRulesPickleball?
  tennisRules              SportRulesTennis?

  @@map("sports")
}

model PlayerSportProfile {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  sportId        String         @map("sport_id") @db.Uuid
  skillLevel     SkillLevelType @default(beginner) @map("skill_level")
  rankingPoints  Int            @default(0) @map("ranking_points")
  isPrimarySport Boolean        @default(false) @map("is_primary_sport")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Restrict)

  @@unique([userId, sportId])
  @@index([userId], map: "idx_player_sport_profiles_user")
  @@map("player_sport_profiles")
}

model Team {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sportId        String?  @map("sport_id") @db.Uuid
  name           String   @db.VarChar(100)
  shortName      String?  @map("short_name") @db.VarChar(10)
  logoUrl        String?  @map("logo_url") @db.Text
  logoBlob       Bytes?   @map("logo_blob")
  logoMimeType   String?  @map("logo_mime_type") @db.VarChar(50)
  description    String?  @db.Text
  captainId      String?  @map("captain_id") @db.Uuid
  viceCaptainId  String?  @map("vice_captain_id") @db.Uuid
  createdBy      String   @map("created_by") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport           Sport?                 @relation(fields: [sportId], references: [id], onDelete: SetNull)
  captain         User?                  @relation("TeamCaptain", fields: [captainId], references: [id], onDelete: SetNull)
  viceCaptain     User?                  @relation("TeamViceCaptain", fields: [viceCaptainId], references: [id], onDelete: SetNull)
  creator         User                   @relation("TeamCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  members         TeamMember[]
  tournamentParticipants TournamentParticipant[]
  tournamentStandings    TournamentStanding[]
  matchParticipants      MatchParticipant[]
  teamStatistics         TeamStatistics?

  @@map("teams")
}

model TeamMember {
  id       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId   String       @map("team_id") @db.Uuid
  userId   String       @map("user_id") @db.Uuid
  role     TeamRoleType @default(member)
  joinedAt DateTime     @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt   DateTime?    @map("left_at") @db.Timestamptz(6)
  isActive Boolean      @default(true) @map("is_active")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId], map: "idx_team_members_team")
  @@index([userId], map: "idx_team_members_user")
  @@map("team_members")
}

model Tournament {
  id                    String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sportId               String                    @map("sport_id") @db.Uuid
  organizerId           String                    @map("organizer_id") @db.Uuid
  name                  String                    @db.VarChar(150)
  format                TournamentFormatType
  participantKind       TournamentParticipantKind @map("participant_kind")
  bannerUrl             String?                   @map("banner_url") @db.Text
  description           String?                   @db.Text
  venue                 String?                   @db.VarChar(200)
  city                  String?                   @db.VarChar(100)
  state                 String?                   @db.VarChar(100)
  country               String?                   @db.VarChar(100)
  registrationStartDate DateTime?                 @map("registration_start_date") @db.Date
  registrationEndDate   DateTime?                 @map("registration_end_date") @db.Date
  startDate             DateTime                  @map("start_date") @db.Date
  endDate               DateTime?                 @map("end_date") @db.Date
  maxParticipants       Int?                      @map("max_participants")
  status                TournamentStatusType      @default(draft)
  createdAt             DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport        Sport                   @relation(fields: [sportId], references: [id], onDelete: Restrict)
  organizer    User                    @relation(fields: [organizerId], references: [id], onDelete: Restrict)
  participants TournamentParticipant[]
  rounds       TournamentRound[]
  standings    TournamentStanding[]
  matches      Match[]

  @@map("tournaments")
}

model TournamentParticipant {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId String                @map("tournament_id") @db.Uuid
  userId       String?               @map("user_id") @db.Uuid
  teamId       String?               @map("team_id") @db.Uuid
  seedNumber   Int?                  @map("seed_number")
  status       ParticipantStatusType @default(registered)
  registeredAt DateTime              @default(now()) @map("registered_at") @db.Timestamptz(6)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@unique([tournamentId, teamId])
  @@index([tournamentId], map: "idx_tournament_participants_tournament")
  @@map("tournament_participants")
}

model TournamentRound {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId String   @map("tournament_id") @db.Uuid
  roundNumber  Int      @map("round_number")
  roundName    String   @map("round_name") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches    Match[]

  @@unique([tournamentId, roundNumber])
  @@map("tournament_rounds")
}

model TournamentStanding {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId   String   @map("tournament_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  teamId         String?  @map("team_id") @db.Uuid
  matchesPlayed  Int      @default(0) @map("matches_played")
  wins           Int      @default(0)
  losses         Int      @default(0)
  points         Int      @default(0)
  position       Int?
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@unique([tournamentId, teamId])
  @@map("tournament_standings")
}

model Match {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sportId           String          @map("sport_id") @db.Uuid
  tournamentId      String?         @map("tournament_id") @db.Uuid
  tournamentRoundId String?         @map("tournament_round_id") @db.Uuid
  matchType         MatchTypeKind   @map("match_type")
  matchFormat       Json            @map("match_format")
  venue             String?         @db.VarChar(200)
  venueId           String?         @map("venue_id") @db.Uuid
  scheduledAt       DateTime?       @map("scheduled_at") @db.Timestamptz(6)
  startedAt         DateTime?       @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime?       @map("finished_at") @db.Timestamptz(6)
  status            MatchStatusType @default(scheduled)
  winnerSide        MatchSideType?  @map("winner_side")
  createdBy         String          @map("created_by") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport           Sport              @relation(fields: [sportId], references: [id], onDelete: Restrict)
  tournament      Tournament?        @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  tournamentRound TournamentRound?   @relation(fields: [tournamentRoundId], references: [id], onDelete: SetNull)
  venueRef        Venue?             @relation(fields: [venueId], references: [id], onDelete: SetNull)
  creator         User               @relation("MatchCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  participants    MatchParticipant[]
  sets            MatchSet[]
  points          MatchPoint[]
  statusLogs      MatchStatusLog[]

  @@index([tournamentId], map: "idx_matches_tournament")
  @@index([status], map: "idx_matches_status")
  @@index([venueId], map: "idx_matches_venue")
  @@map("matches")
}

model MatchParticipant {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId   String        @map("match_id") @db.Uuid
  side      MatchSideType
  userId    String?       @map("user_id") @db.Uuid
  teamId    String?       @map("team_id") @db.Uuid
  isWinner  Boolean       @default(false) @map("is_winner")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([matchId], map: "idx_match_participants_match")
  @@index([userId], map: "idx_match_participants_user")
  @@map("match_participants")
}

model MatchSet {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId     String         @map("match_id") @db.Uuid
  setNumber   Int            @map("set_number")
  sideAScore  Int            @default(0) @map("side_a_score")
  sideBScore  Int            @default(0) @map("side_b_score")
  winnerSide  MatchSideType? @map("winner_side")
  startedAt   DateTime?      @map("started_at") @db.Timestamptz(6)
  endedAt     DateTime?      @map("ended_at") @db.Timestamptz(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  match  Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  points MatchPoint[]

  @@unique([matchId, setNumber])
  @@index([matchId], map: "idx_match_sets_match")
  @@map("match_sets")
}

model MatchPoint {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId         String        @map("match_id") @db.Uuid
  matchSetId      String        @map("match_set_id") @db.Uuid
  pointNumber     Int           @map("point_number")
  scoringSide     MatchSideType @map("scoring_side")
  sideAScoreAfter Int           @map("side_a_score_after")
  sideBScoreAfter Int           @map("side_b_score_after")
  isUndone        Boolean       @default(false) @map("is_undone")
  recordedBy      String        @map("recorded_by") @db.Uuid
  recordedAt      DateTime      @default(now()) @map("recorded_at") @db.Timestamptz(6)

  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchSet MatchSet @relation(fields: [matchSetId], references: [id], onDelete: Cascade)
  recorder User     @relation(fields: [recordedBy], references: [id], onDelete: Restrict)

  @@index([matchSetId], map: "idx_match_points_match_set")
  @@map("match_points")
}

model MatchStatusLog {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId        String           @map("match_id") @db.Uuid
  previousStatus MatchStatusType? @map("previous_status")
  newStatus      MatchStatusType  @map("new_status")
  changedBy      String           @map("changed_by") @db.Uuid
  reason         String?          @db.Text
  changedAt      DateTime         @default(now()) @map("changed_at") @db.Timestamptz(6)

  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  changer User  @relation(fields: [changedBy], references: [id], onDelete: Restrict)

  @@map("match_status_logs")
}

model PlayerStatistics {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  sportId              String   @map("sport_id") @db.Uuid
  matchesPlayed        Int      @default(0) @map("matches_played")
  matchesWon           Int      @default(0) @map("matches_won")
  matchesLost          Int      @default(0) @map("matches_lost")
  setsWon              Int      @default(0) @map("sets_won")
  setsLost             Int      @default(0) @map("sets_lost")
  totalPointsScored    Int      @default(0) @map("total_points_scored")
  totalPointsConceded  Int      @default(0) @map("total_points_conceded")
  winPercentage        Decimal  @default(0) @map("win_percentage") @db.Decimal(5, 2)
  currentRankingPoints Int      @default(0) @map("current_ranking_points")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([userId, sportId])
  @@index([sportId, currentRankingPoints(sort: Desc)], map: "idx_player_statistics_sport_rank")
  @@map("player_statistics")
}

model TeamStatistics {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId         String   @unique @map("team_id") @db.Uuid
  matchesPlayed  Int      @default(0) @map("matches_played")
  matchesWon     Int      @default(0) @map("matches_won")
  matchesLost    Int      @default(0) @map("matches_lost")
  setsWon        Int      @default(0) @map("sets_won")
  setsLost       Int      @default(0) @map("sets_lost")
  winPercentage  Decimal  @default(0) @map("win_percentage") @db.Decimal(5, 2)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_statistics")
}

model Venue {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(150)
  latitude  Float
  longitude Float
  address   String?  @db.VarChar(255)
  city      String?  @db.VarChar(100)
  state     String?  @db.VarChar(100)
  country   String?  @db.VarChar(100)
  createdBy String   @map("created_by") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  creator User    @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  matches Match[]

  @@index([name], map: "idx_venues_name")
  @@index([createdBy], map: "idx_venues_created_by")
  @@index([isActive], map: "idx_venues_active")
  @@map("venues")
}

model SportRulesTableTennis {
  sportId              String   @id @map("sport_id") @db.Uuid
  supportsSingles      Boolean  @default(true) @map("supports_singles")
  supportsDoubles      Boolean  @default(true) @map("supports_doubles")
  supportsTeamMatches  Boolean  @default(false) @map("supports_team_matches")
  usesTeamRoster       Boolean  @default(false) @map("uses_team_roster")
  hasCaptain           Boolean  @default(false) @map("has_captain")
  hasViceCaptain       Boolean  @default(false) @map("has_vice_captain")
  minRosterSize        Int?     @map("min_roster_size")
  maxRosterSize        Int?     @map("max_roster_size")
  minPlayersPerSide    Int      @default(1) @map("min_players_per_side")
  maxPlayersPerSide    Int      @default(2) @map("max_players_per_side")
  matchFormat          Json     @map("match_format")
  scoringConfig        Json     @map("scoring_config")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@map("sport_rules_table_tennis")
}

model SportRulesBadminton {
  sportId              String   @id @map("sport_id") @db.Uuid
  supportsSingles      Boolean  @default(true) @map("supports_singles")
  supportsDoubles      Boolean  @default(true) @map("supports_doubles")
  supportsTeamMatches  Boolean  @default(false) @map("supports_team_matches")
  usesTeamRoster       Boolean  @default(false) @map("uses_team_roster")
  hasCaptain           Boolean  @default(false) @map("has_captain")
  hasViceCaptain       Boolean  @default(false) @map("has_vice_captain")
  minRosterSize        Int?     @map("min_roster_size")
  maxRosterSize        Int?     @map("max_roster_size")
  minPlayersPerSide    Int      @default(1) @map("min_players_per_side")
  maxPlayersPerSide    Int      @default(2) @map("max_players_per_side")
  matchFormat          Json     @map("match_format")
  scoringConfig        Json     @map("scoring_config")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@map("sport_rules_badminton")
}

model SportRulesVolleyball {
  sportId              String   @id @map("sport_id") @db.Uuid
  supportsSingles      Boolean  @default(false) @map("supports_singles")
  supportsDoubles      Boolean  @default(false) @map("supports_doubles")
  supportsTeamMatches  Boolean  @default(true) @map("supports_team_matches")
  usesTeamRoster       Boolean  @default(true) @map("uses_team_roster")
  hasCaptain           Boolean  @default(true) @map("has_captain")
  hasViceCaptain       Boolean  @default(true) @map("has_vice_captain")
  minRosterSize        Int      @default(6) @map("min_roster_size")
  maxRosterSize        Int      @default(15) @map("max_roster_size")
  minPlayersPerSide    Int      @default(6) @map("min_players_per_side")
  maxPlayersPerSide    Int      @default(12) @map("max_players_per_side")
  matchFormat          Json     @map("match_format")
  scoringConfig        Json     @map("scoring_config")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@map("sport_rules_volleyball")
}

model SportRulesPickleball {
  sportId              String   @id @map("sport_id") @db.Uuid
  supportsSingles      Boolean  @default(true) @map("supports_singles")
  supportsDoubles      Boolean  @default(true) @map("supports_doubles")
  supportsTeamMatches  Boolean  @default(false) @map("supports_team_matches")
  usesTeamRoster       Boolean  @default(false) @map("uses_team_roster")
  hasCaptain           Boolean  @default(false) @map("has_captain")
  hasViceCaptain       Boolean  @default(false) @map("has_vice_captain")
  minRosterSize        Int?     @map("min_roster_size")
  maxRosterSize        Int?     @map("max_roster_size")
  minPlayersPerSide    Int      @default(1) @map("min_players_per_side")
  maxPlayersPerSide    Int      @default(2) @map("max_players_per_side")
  matchFormat          Json     @map("match_format")
  scoringConfig        Json     @map("scoring_config")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@map("sport_rules_pickleball")
}

model SportRulesTennis {
  sportId              String   @id @map("sport_id") @db.Uuid
  supportsSingles      Boolean  @default(true) @map("supports_singles")
  supportsDoubles      Boolean  @default(true) @map("supports_doubles")
  supportsTeamMatches  Boolean  @default(false) @map("supports_team_matches")
  usesTeamRoster       Boolean  @default(false) @map("uses_team_roster")
  hasCaptain           Boolean  @default(false) @map("has_captain")
  hasViceCaptain       Boolean  @default(false) @map("has_vice_captain")
  minRosterSize        Int?     @map("min_roster_size")
  maxRosterSize        Int?     @map("max_roster_size")
  minPlayersPerSide    Int      @default(1) @map("min_players_per_side")
  maxPlayersPerSide    Int      @default(2) @map("max_players_per_side")
  matchFormat          Json     @map("match_format")
  scoringConfig        Json     @map("scoring_config")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@map("sport_rules_tennis")
}

model SupportConcern {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(50)
  label       String   @db.VarChar(150)
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  isOther     Boolean  @default(false) @map("is_other")
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  creator User?           @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  tickets SupportTicket[]

  @@index([isActive, sortOrder], map: "idx_support_concerns_active_sort")
  @@map("support_concerns")
}

model SupportTicket {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketNumber     String                   @unique @map("ticket_number") @db.VarChar(30)
  concernId        String                   @map("concern_id") @db.Uuid
  otherConcernText String?                  @map("other_concern_text") @db.VarChar(200)
  description      String                   @db.Text
  status           SupportTicketStatusType  @default(open)
  createdBy        String                   @map("created_by") @db.Uuid
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  concern    SupportConcern            @relation(fields: [concernId], references: [id], onDelete: Restrict)
  creator    User                      @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  images     SupportTicketImage[]
  statusLogs SupportTicketStatusLog[]

  @@index([createdBy], map: "idx_support_tickets_created_by")
  @@index([status], map: "idx_support_tickets_status")
  @@index([concernId], map: "idx_support_tickets_concern")
  @@map("support_tickets")
}

model SupportTicketImage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId     String   @map("ticket_id") @db.Uuid
  imageBlob    Bytes    @map("image_blob")
  mimeType     String   @map("mime_type") @db.VarChar(50)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId], map: "idx_support_ticket_images_ticket")
  @@map("support_ticket_images")
}

model SupportTicketStatusLog {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId       String                  @map("ticket_id") @db.Uuid
  previousStatus SupportTicketStatusType? @map("previous_status")
  newStatus      SupportTicketStatusType @map("new_status")
  changedBy      String                  @map("changed_by") @db.Uuid
  note           String?                 @db.VarChar(500)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket  SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changer User          @relation(fields: [changedBy], references: [id], onDelete: Restrict)

  @@index([ticketId], map: "idx_support_ticket_status_logs_ticket")
  @@map("support_ticket_status_logs")
}
