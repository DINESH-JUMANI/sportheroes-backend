{
  "name": "sportheroes-backend",
  "version": "1.0.0",
  "description": "Sport Heroes scoring engine backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate": "node scripts/run-migration.js",
    "db:migrate:1": "node scripts/run-migration.js 1.add_user.sql"
  },
  "keywords": [
    "express",
    "sports",
    "scoring-engine",
    "table-tennis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.19.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  },
  "overrides": {
    "jose": "^4.15.9"
  }
}
