{
  "name": "sportheroes-backend",
  "version": "1.0.0",
  "description": "Sport Heroes scoring engine backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate": "node scripts/run-migration.js",
    "db:migrate:1": "node scripts/run-migration.js 1.add_user.sql",
    "db:migrate:2": "node scripts/run-migration.js 2.add_sports_and_player_profiles.sql",
    "db:migrate:3": "node scripts/run-migration.js 3.add_teams.sql",
    "db:migrate:4": "node scripts/run-migration.js 4.add_tournaments.sql",
    "db:migrate:5": "node scripts/run-migration.js 5.add_matches.sql",
    "db:migrate:6": "node scripts/run-migration.js 6.add_statistics.sql",
    "db:migrate:7": "node scripts/run-migration.js 7.seed_dev_user.sql",
    "db:migrate:8": "node scripts/run-migration.js 8.seed_dev_user_2.sql",
    "db:migrate:9": "node scripts/run-migration.js 9.seed_sports.sql",
    "db:seed:dev": "node scripts/seed-dev-token.js",
    "db:seed:sports": "node scripts/run-migration.js 9.seed_sports.sql",
    "e2e:auth": "node scripts/e2e/01-auth.e2e.js",
    "e2e:sports": "node scripts/e2e/02-sports.e2e.js",
    "e2e:players": "node scripts/e2e/02b-players.e2e.js",
    "e2e:teams": "node scripts/e2e/03-teams.e2e.js",
    "e2e:tournaments": "node scripts/e2e/04-tournaments.e2e.js",
    "e2e:matches": "node scripts/e2e/05-matches.e2e.js",
    "e2e:statistics": "node scripts/e2e/06-statistics.e2e.js",
    "e2e:all": "node scripts/e2e/run-all.e2e.js",
    "db:migrate:all": "node scripts/run-migration.js 1.add_user.sql && node scripts/run-migration.js 2.add_sports_and_player_profiles.sql && node scripts/run-migration.js 3.add_teams.sql && node scripts/run-migration.js 4.add_tournaments.sql && node scripts/run-migration.js 5.add_matches.sql && node scripts/run-migration.js 6.add_statistics.sql && node scripts/run-migration.js 9.seed_sports.sql"
  },
  "keywords": [
    "express",
    "sports",
    "scoring-engine",
    "table-tennis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.19.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
